{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "incremental": false,
    "types": ["node"]
  },
  "include": [
    "examples/vanilla-html.ts",
    "examples/basic-validation.ts",
    "examples/wizard-workflow.ts"
  ]
}
