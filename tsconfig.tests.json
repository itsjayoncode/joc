{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true
  },
  "include": [
    "packages/**/*.test.ts",
    "packages/**/*.spec.ts",
    "packages/**/*.test.tsx",
    "packages/**/*.spec.tsx",
    "packages/**/*.contract.ts",
    "packages/form-intelligence/tests/contracts/**/*.ts",
    "apps/browser-session-playground/src/**/*.test.ts",
    "apps/browser-session-playground/src/**/*.spec.ts",
    "apps/browser-session-playground/src/**/*.test.tsx",
    "apps/browser-session-playground/src/**/*.spec.tsx",
    "apps/object-diff-playground/src/**/*.test.ts",
    "apps/object-diff-playground/src/**/*.spec.ts",
    "apps/object-diff-playground/src/**/*.test.tsx",
    "apps/object-diff-playground/src/**/*.spec.tsx",
    "apps/form-intelligence-playground/src/**/*.test.ts",
    "apps/form-intelligence-playground/src/**/*.spec.ts",
    "apps/form-intelligence-playground/src/**/*.test.tsx",
    "apps/form-intelligence-playground/src/**/*.spec.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "scripts/doc-versioning-policy.ts",
    "test-utils/**/*.ts",
    "test-utils/**/*.tsx"
  ],
  "exclude": ["coverage", "dist", "build", "lib", "node_modules"]
}
